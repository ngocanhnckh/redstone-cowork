# ---- Instance identity (PRD 006 FR-1/FR-2) ----
# `deploy/remote.sh init` overwrites COMPOSE_PROJECT_NAME + the two ports below with
# a unique name and a free uncommon port pair (scanned live on the host, confirmed
# with you) so many installs can share one server without colliding. Edit by hand
# only if you are setting up a single/standalone instance.
INSTANCE_ID=default
COMPOSE_PROJECT_NAME=rcw-default

# ---- Ports (host-side; containers use fixed internal ports) ----
WEB_PORT=47100
API_PORT=47101

# ---- Secrets ----
POSTGRES_PASSWORD=change-me-postgres
INSTANCE_TOKEN=change-me-token

# ---- Connector credential vault (M2) ----
# 32 bytes, base64. Generate once: `openssl rand -base64 32`
# Required to add integrations; encrypts connector tokens at rest.
CRED_ENCRYPTION_KEY=

# ---- Web Push (phone notifications) ----
# Generate a keypair once: `npx web-push generate-vapid-keys`
# Leave blank to disable push (the web hides the "Enable notifications" button).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- Google (Gmail + Calendar) OAuth ----
# OAuth client (Web application) from Google Cloud Console → APIs & Services → Credentials.
# Authorized redirect URI must be ${OAUTH_REDIRECT_BASE}/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=https://cowork.example.com

# ---- Microsoft (Outlook mail + calendar) OAuth ----
# Azure AD app registration (audience: personal + work/school accounts) via Microsoft Graph.
# Redirect URI must be ${OAUTH_REDIRECT_BASE}/api/oauth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ---- LLM inference (OpenAI-compatible) — powers the cockpit assistant ----
# Mirror the `# OPENAI LLM INFER` block in .creds. Each tier needs all three vars
# or it is omitted from the model list. text = large, flash = fast/small, vision = multimodal.
OPENAI_TEXT_BASE_URL=
OPENAI_TEXT_KEY=
OPENAI_TEXT_MODEL=
OPENAI_FLASH_BASE_URL=
OPENAI_FLASH_KEY=
OPENAI_FLASH_MODEL=
OPENAI_VISION_BASE_URL=
OPENAI_VISION_KEY=
OPENAI_VISION_MODEL=
# Token budgets (optional): context is hard-capped under 100k regardless.
LLM_MAX_CONTEXT_TOKENS=12000
LLM_MAX_OUTPUT_TOKENS=1024

# ---- Agent tools ----
# Tavily web search (https://tavily.com) — enables the assistant's Agent mode.
TAVILY_KEY=

# ---- Redstone as OIDC auth provider (org mode) ----
# Set all three to let org users sign in with their Redstone account (and to let
# the assistant call the Redstone agent as the user). Leave blank for personal
# mode (instance-token auth only). ISSUER = the reachable Redstone origin.
REDSTONE_ISSUER=
REDSTONE_CLIENT_ID=
REDSTONE_CLIENT_SECRET=
