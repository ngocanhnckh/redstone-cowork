{
  "name": "@rcw/desktop",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ngocanhnckh/redstone-cowork.git"
  },
  "scripts": {
    "postinstall": "node scripts/fix-native-perms.cjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "start": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w node-pty",
    "dist": "electron-vite build && electron-builder --config electron-builder.yml",
    "dist:dir": "electron-vite build && electron-builder --config electron-builder.yml --dir",
    "geoip": "node scripts/fetch-geoip.mjs"
  },
  "dependencies": {
    "@vladmandic/face-api": "^1.7.15",
    "maxmind": "^5.0.6",
    "node-mac-permissions": "^2.5.0",
    "node-pty": "^1.0.0"
  },
  "//deps": "Only node-pty ships at runtime (it's a native module, externalized in electron.vite.config). Everything else is bundled into out/ by vite, so it's build-time only — keeping it out of `dependencies` stops electron-builder from packaging (and, for @rcw/shared, choking on) the workspace tree.",
  "devDependencies": {
    "@blocknote/core": "^0.51.4",
    "@blocknote/mantine": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@electron/rebuild": "^3.7.1",
    "@monaco-editor/react": "^4.7.0",
    "@rcw/shared": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "jsdom": "^25.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "mermaid": "^11.16.0",
    "monaco-editor": "^0.52.2",
    "motion": "^12.42.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.2"
  }
}
